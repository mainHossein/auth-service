#################################################
# Application
#################################################

APP_PORT=8080

#################################################
# Postgresql
#################################################

POSTGRES_VERSION=17.6
POSTGRES_DB=auth_service
POSTGRES_USER=auth_service_user
POSTGRES_PASSWORD=AuthAdmin
POSTGRES_PORT=5432

#################################################
# Redis
#################################################

REDIS_VERSION=8.2
REDIS_PORT=6379

#################################################
# Elastic Stack
# Keep all Elastic components on the same version.
#################################################

ELASTIC_VERSION=9.3.7
ELASTICSEARCH_PORT=9200

KIBANA_VERSION=9.4.3
KIBANA_PORT=5601

FILEBEAT_VERSION=9.4.3

#################################################
# Elasticsearch JVM
#################################################

ES_JAVA_OPTS=-Xms1g -Xmx1g